{
  "name": "cursor-thief",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "description": "A tiny creature steals your selected text and brings it back.",
  "homepage": "https://github.com/inderjotpujara/cursor-thief",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/inderjotpujara/cursor-thief.git"
  },
  "bugs": {
    "url": "https://github.com/inderjotpujara/cursor-thief/issues"
  },
  "scripts": {
    "dev": "node scripts/build.mjs --target=chromium --watch",
    "build": "npm run build:chromium && npm run build:firefox",
    "build:chromium": "node scripts/build.mjs --target=chromium",
    "build:firefox": "node scripts/build.mjs --target=firefox",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "webextension-polyfill": "^0.12.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.270",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/webextension-polyfill": "^0.12.1",
    "@vitejs/plugin-react": "^4.3.3",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
